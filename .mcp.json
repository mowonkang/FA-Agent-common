{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": ".claude/memory.json"
      }
    },
    "excel": {
      "command": "uvx",
      "args": ["excel-mcp-server", "stdio"],
      "env": {
        "EXCEL_FILES_PATH": "."
      }
    }
  }
}
